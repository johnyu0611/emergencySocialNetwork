{
  "name": "emergency-social-network",
  "version": "0.0.1",
  "description": "Emergency Social Network, or ESN, is to provide civilians with a social network that they can use during emergency situations. The system is different from other existing social networks because it is specifically designed to effectively support small communities of civilians seriously affected in case of natural disasters like earthquake, tsunami, tornado, wildfire, etc.",
  "main": "main.mjs",
  "scripts": {
    "dev": "DEVELOPMENT=true node --import ./src/ESMLoader.mjs ./src/main.mjs",
    "format": "prettier --write ./src ./public",
    "lint": "eslint",
    "test": "jest",
    "serve": "node --import ./src/ESMLoader.mjs ./src/main.mjs",
    "help": "node --import ./src/ESMLoader.mjs ./src/main.mjs -h",
    "ci-check-code-style": "prettier --check ./src ./public",
    "ci-lint": "eslint",
    "ci-test": "jest"
  },
  "author": "FSE Team SB-1",
  "type": "module",
  "dependencies": {
    "@testing-library/dom": "^10.4.0",
    "argon2": "^0.41.1",
    "commander": "^12.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "enum": "^3.0.4",
    "esm-module-alias": "^2.2.1",
    "express": "^5.0.1",
    "fs": "^0.0.1-security",
    "jsdom": "^25.0.1",
    "jsonwebtoken": "^9.0.2",
    "mongodb-memory-server": "^10.1.2",
    "mongoose": "^8.8.3",
    "ms": "^2.1.3",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "Prettier": "npm:prettier@^3.3.3",
    "sharp": "^0.33.5",
    "socket.io": "^4.8.1",
    "uuid": "^11.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@babel/plugin-transform-modules-commonjs": "^7.25.9",
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.15.0",
    "@jest/globals": "^29.7.0",
    "@testing-library/jest-dom": "^6.6.3",
    "babel-jest": "^29.7.0",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.3.3"
  },
  "aliases": {
    "@": "./src",
    "!config": "./app.config.mjs"
  }
}
