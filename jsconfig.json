{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "checkJs": true,
    "baseUrl": "./src",
    "paths": {
      "@/*": [
        "./*"
      ],
      "!config": [
        "./app.config.mjs"
      ]
    }
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules"
  ]
}